{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/**", "function": "api" },
      { "source": "/",       "destination": "/detect.html"  },
      { "source": "/m",      "destination": "/mobile.html"  },
      { "source": "/app",    "destination": "/index.html"   }
    ]
  },
  "functions": {
    "source": "functions"
  }
}
